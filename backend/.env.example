# ============================================================
# CIE-2 Activity Management System — Environment Configuration
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to ".env" in the same folder (backend/)
#   2. Fill in your local MySQL credentials below
#   3. Never commit .env to Git (it's already in .gitignore)
# ============================================================

# ----- Server -----
PORT=5000

# ----- Database (MySQL via XAMPP or MySQL Workbench) -----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=cie2_db

# ----- JSON Web Token -----
# Use any long, random secret string. Keep it private.
JWT_SECRET=replace_this_with_a_long_random_secret_string

# ----- App Environment -----
NODE_ENV=development
